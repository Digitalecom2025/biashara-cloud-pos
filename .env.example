# Biashara Cloud POS environment template.
# Do not commit real production secrets.

# Local development:
# The default local demo can use SQLite with prisma/schema.prisma.
DATABASE_URL="file:./dev.db"

# Vercel demo:
# Use a hosted PostgreSQL connection string from Prisma Postgres, Neon,
# Supabase, or another Vercel Marketplace Postgres provider.
# Example:
# DATABASE_URL="postgres://USER:PASSWORD@HOST:PORT/DATABASE"

NEXT_PUBLIC_APP_NAME="Biashara Cloud POS"
NEXT_PUBLIC_DEMO_MODE="true"
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Internal Super Admin login.
# Set strong values in local/prod .env. Do not expose these as NEXT_PUBLIC_*.
SUPER_ADMIN_EMAIL="admin@example.com"
SUPER_ADMIN_PASSWORD="change-this-strong-password"

# SMS provider settings. SMS is disabled unless NEXT_PUBLIC_SMS_ENABLED is true
# and provider credentials are configured.
NEXT_PUBLIC_SMS_ENABLED="false"
SMS_PROVIDER=""
SMS_API_KEY=""
SMS_USERNAME=""
SMS_SENDER_ID=""
NEXT_PUBLIC_SUPPORT_EMAIL="admin@integratedrevenue.co.ke"
NEXT_PUBLIC_SUPPORT_WHATSAPP=""
